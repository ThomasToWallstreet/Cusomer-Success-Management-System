generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Stage {
  BASIC_INFO
  BUSINESS_GOAL
  ORG_RELATION
  SUCCESS_DEFINITION
  KEY_ACTIVITIES
  EXECUTION
}

enum StageStatus {
  IN_PROGRESS
  BLOCKED
  DONE
}

enum RiskLevel {
  GREEN
  YELLOW
  RED
}

enum ExecutionSourceType {
  HEADQUARTERS
  REGIONAL
}

enum ExecutionActionStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ExecutionActionEventType {
  CREATED
  STATUS_CHANGED
  DEADLINE_CHANGED
  NOTE_UPDATED
  UPDATED
  ARCHIVED
}

enum ExecutionActionChangeSource {
  UI_EXECUTION
  UI_WEEKLY_QUICK
  SYSTEM_SYNC
}

model Customer {
  id               String               @id @default(cuid())
  name             String               @unique
  industry         String?
  tier             String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  contacts         CustomerContact[]
  projectItems     CustomerProjectItem[]
  scenarioItems    CustomerScenarioItem[]
  scenarios        KeySuccessScenario[]
  weeklyReports    WeeklyReport[]
  goalSnapshots    CustomerGoalWeeklySnapshot[]
  assignments      ManagerCustomerAssignment[]
  customerListItem CustomerListEntry?
}

model CustomerContact {
  id                  String   @id @default(cuid())
  customerId          String
  name                String
  department          String?
  level               String?
  satisfactionCurrent String   @default("无感知")
  satisfactionTarget  String   @default("认可")
  satisfactionUpdatedAt DateTime?
  satisfactionEvidence String?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  satisfactionHistories CustomerContactSatisfactionHistory[]
  scenarios           KeySuccessScenario[]

  @@unique([customerId, name])
  @@index([customerId])
  @@index([customerId, satisfactionCurrent])
}

model CustomerContactSatisfactionHistory {
  id                  String          @id @default(cuid())
  contactId           String
  satisfactionCurrent String
  satisfactionUpdatedAt DateTime
  satisfactionEvidence String
  createdAt           DateTime        @default(now())
  contact             CustomerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, satisfactionUpdatedAt])
}

model CustomerProjectItem {
  id                   String   @id @default(cuid())
  customerId           String
  name                 String
  productLine          String?
  targetDimension      Json?
  targetDescription    String?
  businessStage        String?
  businessGoalAchieved String?
  businessGoalUpdatedAt DateTime?
  businessGoalEvidence String?
  keyScenarioDescription String?
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  businessGoalHistories CustomerProjectBusinessGoalHistory[]
  scenarios            KeySuccessScenario[]

  @@unique([customerId, name])
  @@index([customerId])
}

model CustomerProjectBusinessGoalHistory {
  id                   String              @id @default(cuid())
  projectItemId        String
  businessGoalAchieved String
  businessGoalUpdatedAt DateTime
  businessGoalEvidence String
  createdAt            DateTime            @default(now())
  projectItem          CustomerProjectItem @relation(fields: [projectItemId], references: [id], onDelete: Cascade)

  @@index([projectItemId, businessGoalUpdatedAt])
}

model CustomerScenarioItem {
  id                     String   @id @default(cuid())
  customerId             String
  name                   String
  keyScenarioDescription String?
  businessNeedAnalysis   String?
  personalNeeds          String?
  smartGoal              String?
  alignedWithCustomer    String?
  alignedUpdatedAt       DateTime?
  alignedEvidence        String?
  note                   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  alignmentHistories     CustomerScenarioAlignmentHistory[]
  attachments            CustomerScenarioAttachment[]
  scenarios              KeySuccessScenario[]

  @@unique([customerId, name])
  @@index([customerId])
}

model CustomerScenarioAlignmentHistory {
  id                  String               @id @default(cuid())
  scenarioItemId      String
  alignedWithCustomer String
  alignedUpdatedAt    DateTime
  alignedEvidence     String
  createdAt           DateTime             @default(now())
  scenarioItem        CustomerScenarioItem @relation(fields: [scenarioItemId], references: [id], onDelete: Cascade)

  @@index([scenarioItemId, alignedUpdatedAt])
}

model CustomerScenarioAttachment {
  id             String               @id @default(cuid())
  scenarioItemId String
  originalName   String
  storedName     String
  fileUrl        String
  mimeType       String?
  fileSize       Int
  createdAt      DateTime             @default(now())
  scenarioItem   CustomerScenarioItem @relation(fields: [scenarioItemId], references: [id], onDelete: Cascade)

  @@index([scenarioItemId, createdAt])
}

model ManagerCustomerAssignment {
  id         String   @id @default(cuid())
  managerName String
  customerId String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([managerName, customerId])
  @@index([managerName])
  @@index([customerId])
}

model KeySuccessScenario {
  id                 String               @id @default(cuid())
  customer           String
  customerId         String?
  projectItemId      String?
  contactId          String?
  scenarioItemId     String?
  keyPerson          String
  keyPersonDept      String?
  keyProjectScenario String
  productLine        String?
  ownerName          String
  stage              Stage                @default(BASIC_INFO)
  stageStatus        StageStatus          @default(IN_PROGRESS)
  riskLevel          RiskLevel            @default(GREEN)
  nextAction         String?
  goalSection        Json?
  orgSection         Json?
  successSection     Json?
  activitySection    Json?
  executionSection   Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  weeklyReportLinks  WeeklyReportThread[]
  executionActions   ExecutionAction[]
  customerRecord     Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectItem        CustomerProjectItem? @relation(fields: [projectItemId], references: [id], onDelete: SetNull)
  contactRecord      CustomerContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  scenarioItem       CustomerScenarioItem? @relation(fields: [scenarioItemId], references: [id], onDelete: SetNull)

  @@index([customer])
  @@index([customerId])
  @@index([projectItemId])
  @@index([contactId])
  @@index([scenarioItemId])
  @@index([ownerName])
  @@index([riskLevel, stage])
}

model WeeklyReport {
  id             String               @id @default(cuid())
  customerId     String?
  ownerName      String
  weekStart      DateTime
  weekEnd        DateTime
  summary        String
  risks          String?
  nextWeekPlan   String?
  needSupport    String?
  weeklyObjectives       Json?
  plannedExecutionItems  Json?
  executedItems          Json?
  qualitativeConclusions Json?
  satisfactionRiskLevel  String?
  satisfactionRiskReason String?
  requiredNextActions    Json?
  createdAt      DateTime             @default(now())
  threadLinks    WeeklyReportThread[]
  actionSnapshots WeeklyReportActionSnapshot[]
  customerRecord Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([ownerName, weekStart])
  @@index([customerId, weekStart])
}

model ExecutionAction {
  id          String                @id @default(cuid())
  threadId    String
  externalKey String
  goalKey     String
  sourceType  ExecutionSourceType
  title       String
  ownerName   String
  status      ExecutionActionStatus @default(TODO)
  planStartAt DateTime?
  deadlineAt  DateTime?
  closedAt    DateTime?
  note        String?
  isArchived  Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  thread      KeySuccessScenario    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  events      ExecutionActionEvent[]
  snapshots   WeeklyReportActionSnapshot[]

  @@unique([threadId, externalKey])
  @@index([threadId, status])
  @@index([threadId, deadlineAt])
  @@index([goalKey])
}

model ExecutionActionEvent {
  id         String                      @id @default(cuid())
  actionId   String
  eventType  ExecutionActionEventType
  beforeValue Json?
  afterValue Json?
  changedBy  String?
  source     ExecutionActionChangeSource @default(UI_EXECUTION)
  changedAt  DateTime                    @default(now())
  action     ExecutionAction             @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId, changedAt])
  @@index([eventType, changedAt])
}

model WeeklyReportActionSnapshot {
  id                 String                @id @default(cuid())
  weeklyReportId     String
  actionId           String
  baselineStatus     ExecutionActionStatus
  baselineDeadlineAt DateTime?
  baselineClosedAt   DateTime?
  capturedAt         DateTime              @default(now())
  weeklyReport       WeeklyReport          @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  action             ExecutionAction       @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([weeklyReportId, actionId])
  @@index([actionId])
}

model WeeklyReportThread {
  id             String             @id @default(cuid())
  weeklyReportId String
  threadId       String
  weeklyReport   WeeklyReport       @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  thread         KeySuccessScenario @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([weeklyReportId, threadId])
  @@index([threadId])
}

model CustomerListEntry {
  id                  String   @id @default(cuid())
  customerId          String   @unique
  customerName        String
  groupBranch         String?
  industry            String?
  customerType        String?
  customerStage       String?
  annualCapacity      String?
  order25             String?
  performance25       String?
  order26             String?
  performance26       String?
  growthOrder         String?
  growthPerformance   String?
  sales               String?
  preSalesSecurity    String?
  preSalesCloud       String?
  accountServiceManager String?
  remark              String?
  sourceBatch         String?
  importedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([accountServiceManager])
  @@index([industry])
  @@index([customerType])
  @@index([customerStage])
}

model CustomerGoalWeeklySnapshot {
  id            String   @id @default(cuid())
  customerId    String
  weekStart     DateTime
  revenueRate   Float
  orgRate       Float
  valueRate     Float
  scenarioCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, weekStart])
  @@index([weekStart])
  @@index([customerId, weekStart])
}
